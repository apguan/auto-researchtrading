# Hyperliquid
# Your Ethereum private key (with or without 0x prefix)
HYPERLIQUID_PRIVATE_KEY=

# Trading
DRY_RUN=true
TRADING_PAIRS=BTC,ETH,SOL
MAX_LEVERAGE=3
MAX_POSITION_PCT=0.30
DAILY_LOSS_LIMIT_PCT=0.05

# Alerts (optional — bot works without these)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Paths
DB_PATH=trading_bot.db

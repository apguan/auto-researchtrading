# ── Hyperliquid ──────────────────────────────────────────────────
# Your Ethereum private key (with or without 0x prefix).
# This can be your main wallet PK or an API wallet PK.
HYPERLIQUID_PRIVATE_KEY=

# If using an API wallet, set this to your main wallet address.
# The API wallet signs orders; the main wallet holds the funds.
# Leave blank if HYPERLIQUID_PRIVATE_KEY is your main wallet's key.
HYPERLIQUID_MAIN_WALLET=

# ── Database ─────────────────────────────────────────────────────
# Supabase PostgreSQL — stores experiment results and active strategy params.
# Get from: Supabase Dashboard → Connect → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.vseezosbnrdyhzegsdns.supabase.co:5432/postgres

# ── Trading ──────────────────────────────────────────────────────
DRY_RUN=true
# TRADING_PAIRS auto-derived from DB snapshot or API discovery.
# Override here if needed:
# TRADING_PAIRS=BTC,ETH,SOL,XRP,HYPE
MAX_LEVERAGE=20
MAX_POSITION_PCT=0.30
DAILY_LOSS_LIMIT_PCT=0.05

# ── Timeframe & Strategy ────────────────────────────────────────
# Available: 1m, 5m, 15m (recommended), 1h
# Each interval auto-selects the matching strategy from live_trading_bot/strategies/
BAR_INTERVAL=15m
# Override auto-selection (optional, e.g. "strategies.strategy_15m")
# STRATEGY_MODULE=

# ── Dry Run ──────────────────────────────────────────────────────
DRY_RUN_INITIAL_CAPITAL=10000

# ── Alerts (optional — bot works without these) ─────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── Paths ────────────────────────────────────────────────────────
DB_PATH=trading_bot.db
